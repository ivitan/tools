# EditorConfig 配置文件
# 所有编辑器统一使用这个配置

root = true

# 所有文件
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# HTML 文件
[*.html]
indent_style = space
indent_size = 2

# CSS 文件
[*.css]
indent_style = space
indent_size = 2

# JavaScript 文件
[*.js]
indent_style = space
indent_size = 2

# JSON 文件
[*.json]
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
